---
import type { BlogFaq } from "../../data/blogTypes";

interface Props {
  items: BlogFaq[];
  title: string;
  headingId: string;
  class?: string;
}

const { items, title, headingId, class: className } = Astro.props;
---

{
  items.length > 0 && (
    <section class:list={["blog-faq-accordion", className]} aria-labelledby={headingId}>
      <h2 id={headingId} class="blog-faq-accordion__title">
        {title}
      </h2>
      <div class="blog-faq-accordion__list">
        {items.map((item) => (
          <details class="blog-faq-accordion__item group">
            <summary class="blog-faq-accordion__question">
              <span class="blog-faq-accordion__question-text">{item.question}</span>
              <span class="blog-faq-accordion__toggle" aria-hidden="true">
                <svg
                  class="blog-faq-accordion__chevron"
                  width="12"
                  height="12"
                  viewBox="0 0 12 12"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M2.5 4.5L6 8l3.5-3.5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </summary>
            <div class="blog-faq-accordion__answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </section>
  )
}

<style>
  .blog-faq-accordion {
    border: 1px solid var(--color-border-strong);
    border-radius: 0.75rem;
    background: var(--color-surface-elevated);
    padding: 1.25rem 1.25rem 0.5rem;
  }

  .blog-faq-accordion__title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-ink);
  }

  .blog-faq-accordion__list {
    margin-top: 0.25rem;
  }

  .blog-faq-accordion__item {
    border-bottom: 1px solid var(--color-border);
  }

  .blog-faq-accordion__item:last-child {
    border-bottom: none;
  }

  .blog-faq-accordion__question {
    display: flex;
    cursor: pointer;
    list-style: none;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.45;
    color: var(--color-ink);
  }

  .blog-faq-accordion__question::-webkit-details-marker {
    display: none;
  }

  .blog-faq-accordion__question::marker {
    content: "";
  }

  .blog-faq-accordion__question:hover .blog-faq-accordion__question-text {
    color: var(--color-accent);
  }

  .blog-faq-accordion__question-text {
    flex: 1;
    transition: color 0.15s ease;
  }

  .blog-faq-accordion__toggle {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    background: var(--color-surface-muted);
    color: var(--color-ink-muted);
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }

  .blog-faq-accordion__item[open] .blog-faq-accordion__toggle {
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface-muted));
    color: var(--color-accent);
  }

  .blog-faq-accordion__chevron {
    transition: transform 0.2s ease;
  }

  .blog-faq-accordion__item[open] .blog-faq-accordion__chevron {
    transform: rotate(180deg);
  }

  .blog-faq-accordion__answer {
    padding: 0 0 1rem;
  }

  .blog-faq-accordion__answer p {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-ink-muted);
  }
</style>
