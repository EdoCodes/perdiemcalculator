---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogFaqAccordion from "./BlogFaqAccordion.astro";
import BlogPeopleAlsoAsk from "./BlogPeopleAlsoAsk.astro";
import BlogRunNumbersCta from "./BlogRunNumbersCta.astro";
import {
  BLOG_INDEX,
  type BlogPost,
  blogCategoryLabel,
  formatBlogDate
} from "../../data/blogPosts";
import type { BlogBlock } from "../../data/blogTypes";
import type { BlogFaq } from "../../data/blogTypes";

type Props = {
  post: BlogPost;
  blocks: BlogBlock[];
};

const { post, blocks } = Astro.props;
const faqs = post.faqs ?? [];
const peopleAlsoAsk = post.peopleAlsoAsk ?? [];

function uniqueFaqs(items: BlogFaq[]): BlogFaq[] {
  const seen = new Set<string>();
  return items.filter((item) => {
    const key = item.question.trim().toLowerCase();
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

const schemaFaqs = uniqueFaqs([...peopleAlsoAsk, ...faqs]);
const siteUrl = Astro.site?.href ?? Astro.url.origin;
const pageUrl = new URL(`/blog/${post.slug}/`, siteUrl).href;
const pageTitle = post.metaTitle ?? post.title;

function linkifyPaths(text: string): string {
  return text.replace(
    /(\/[a-z0-9\-/]+)/gi,
    '<a href="$1" class="font-medium text-[var(--color-accent)] hover:underline">$1</a>'
  );
}

/** Skip auto-linkify when markup is present — avoids breaking tags like </strong> via `/strong`. */
function hasHtmlMarkup(text: string): boolean {
  return /<[a-z]/i.test(text);
}

function renderHtml(html: string): string {
  if (hasHtmlMarkup(html)) return html;
  return linkifyPaths(html);
}

function renderListItem(item: string): string {
  if (hasHtmlMarkup(item)) return item;
  return linkifyPaths(item);
}

const articleLd = {
  "@type": "BlogPosting",
  headline: post.title,
  description: post.description,
  datePublished: post.publishedAt,
  dateModified: post.publishedAt,
  url: pageUrl,
  mainEntityOfPage: pageUrl,
  author: { "@type": "Organization", name: "PerDiemCalculator" },
  publisher: { "@type": "Organization", name: "PerDiemCalculator" }
};

const faqLd =
  schemaFaqs.length > 0
    ? {
        "@type": "FAQPage",
        mainEntity: schemaFaqs.map((f) => ({
          "@type": "Question",
          name: f.question,
          acceptedAnswer: { "@type": "Answer", text: f.answer }
        }))
      }
    : null;

const jsonLd = faqLd ? [articleLd, faqLd] : articleLd;

const toc = blocks.filter((b) => b.type === "h2" && "id" in b && b.id);
---

<BaseLayout title={`${pageTitle} | Blog`} description={post.description} jsonLd={jsonLd}>
  <article class="mx-auto max-w-3xl" itemscope itemtype="https://schema.org/BlogPosting">
    <meta itemprop="headline" content={post.title} />
    <meta itemprop="datePublished" content={post.publishedAt} />

    <nav class="text-sm text-[var(--color-ink-muted)]" aria-label="Breadcrumb">
      <a class="hover:text-[var(--color-accent)]" href="/">Home</a>
      <span class="mx-2">/</span>
      <a class="hover:text-[var(--color-accent)]" href={BLOG_INDEX}>Blog</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-ink)]">{post.title}</span>
    </nav>

    <p class="mt-6 text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)]">
      {blogCategoryLabel(post.category)} · {formatBlogDate(post.publishedAt)}
    </p>
    <h1 class="blog-heading font-display mt-3 text-3xl sm:text-4xl" itemprop="name">{post.title}</h1>
    <p class="mt-4 text-lg leading-relaxed text-[var(--color-ink-muted)]" itemprop="description">
      {post.description}
    </p>

    {
      toc.length > 0 && (
        <nav
          class="mt-8 rounded-xl border border-[var(--color-border-strong)] bg-[var(--color-surface-elevated)] p-5"
          aria-label="On this page"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-ink-muted)]">
            On this page
          </p>
          <ol class="mt-3 list-decimal space-y-1.5 pl-5 text-sm">
            {toc.map((h) => h.type === "h2" && h.id && (
              <li>
                <a class="blog-heading-link text-[var(--color-ink-muted)]" href={`#${h.id}`}>
                  {h.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }

    <div class="prose-blog mt-10 space-y-6 text-base leading-relaxed text-[var(--color-ink-muted)]">
      {
        blocks.map((block) => {
          if (block.type === "callout") {
            return (
              <aside
                class="blog-rubric rounded-xl border border-[var(--color-accent)]/40 bg-[var(--color-accent-muted)] px-5 py-4"
                role="note"
              >
                <p class="blog-rubric-label text-xs font-bold uppercase tracking-widest text-[var(--color-accent)]">
                  {block.title}
                </p>
                <ul class="mt-3 space-y-2 text-sm text-[var(--color-ink-muted)]">
                  {block.items.map((item) => (
                    <li set:html={renderHtml(item)} />
                  ))}
                </ul>
              </aside>
            );
          }
          if (block.type === "h2") {
            return (
              <h2 id={block.id} class:list={["blog-heading", block.id ? "scroll-mt-24" : ""]}>
                {block.text}
              </h2>
            );
          }
          if (block.type === "h3") {
            return <h3 class="blog-heading">{block.text}</h3>;
          }
          if (block.type === "ul") {
            return (
              <ul>
                {block.items.map((item) => (
                  <li set:html={renderListItem(item)} />
                ))}
              </ul>
            );
          }
          if (block.type === "ol") {
            return (
              <ol>
                {block.items.map((item) => (
                  <li set:html={renderListItem(item)} />
                ))}
              </ol>
            );
          }
          if (block.type === "table") {
            return (
              <div class="overflow-x-auto">
                <table class="w-full min-w-[20rem] border-collapse text-sm">
                  <thead>
                    <tr>
                      {block.headers.map((h) => (
                        <th class="border border-[var(--color-border-strong)] bg-[var(--color-surface-muted)] px-3 py-2 text-left font-semibold text-[var(--color-ink)]">
                          {h}
                        </th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {block.rows.map((row) => (
                      <tr>
                        {row.map((cell) => (
                          <td class="border border-[var(--color-border)] px-3 py-2 text-[var(--color-ink-muted)]">
                            {cell}
                          </td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            );
          }
          if (block.type === "html") {
            return <p set:html={renderHtml(block.html)} />;
          }
          return <p set:html={renderHtml(block.text)} />;
        })
      }
    </div>

    <BlogFaqAccordion
      items={faqs}
      title="Frequently asked questions"
      headingId="faq-heading"
      class="mt-14"
    />

    <BlogPeopleAlsoAsk items={peopleAlsoAsk} class="mt-14" />

    <BlogRunNumbersCta class="mt-14" />

    <p class="mt-12 text-sm text-[var(--color-ink-muted)]">
      <a href={BLOG_INDEX} class="font-semibold text-[var(--color-accent)] hover:underline">
        ← Back to blog
      </a>
    </p>
  </article>
</BaseLayout>

<style>
  .prose-blog :global(h2) {
    margin-top: 2.5rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
  }
  .prose-blog :global(h3) {
    margin-top: 1.5rem;
    font-size: 1.0625rem;
    font-weight: 600;
  }
  .prose-blog :global(ul),
  .prose-blog :global(ol) {
    padding-left: 1.25rem;
  }
  .prose-blog :global(ul) {
    list-style: disc;
  }
  .prose-blog :global(ol) {
    list-style: decimal;
  }
  .prose-blog :global(li) {
    margin-top: 0.35rem;
  }
  .prose-blog :global(a) {
    font-weight: 500;
    color: var(--color-accent);
  }
  .prose-blog :global(strong) {
    color: inherit;
    font-weight: 600;
  }
  .blog-rubric :global(strong) {
    color: inherit;
    font-weight: 600;
  }
  .blog-rubric-label {
    letter-spacing: 0.08em;
  }
</style>
