---
import type { BlogFaq } from "../../data/blogTypes";
import BlogFaqAccordion from "./BlogFaqAccordion.astro";

interface Props {
  items: BlogFaq[];
  class?: string;
}

const { items, class: className } = Astro.props;
---

<BlogFaqAccordion
  items={items}
  title="People also ask"
  headingId="people-also-ask-heading"
  class={className}
/>
