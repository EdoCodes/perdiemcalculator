---
import type { BlogFaq } from "../../data/blogTypes";

interface Props {
  items: BlogFaq[];
  class?: string;
}

const { items, class: className } = Astro.props;
---

{
  items.length > 0 && (
    <section
      class:list={["paa-rubric", className]}
      aria-labelledby="people-also-ask-heading"
    >
      <h2 id="people-also-ask-heading" class="paa-rubric__title">
        People also ask
      </h2>
      <div class="paa-rubric__list">
        {items.map((item) => (
          <details class="paa-rubric__item group">
            <summary class="paa-rubric__question">
              <span class="paa-rubric__question-text">{item.question}</span>
              <span class="paa-rubric__toggle" aria-hidden="true">
                <svg
                  class="paa-rubric__chevron"
                  width="12"
                  height="12"
                  viewBox="0 0 12 12"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M2.5 4.5L6 8l3.5-3.5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </summary>
            <div class="paa-rubric__answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </section>
  )
}

<style>
  .paa-rubric {
    border: 1px solid var(--color-border-strong);
    border-radius: 0.75rem;
    background: var(--color-surface-elevated);
    padding: 1.25rem 1.25rem 0.5rem;
  }

  .paa-rubric__title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-ink);
  }

  .paa-rubric__list {
    margin-top: 0.25rem;
  }

  .paa-rubric__item {
    border-bottom: 1px solid var(--color-border);
  }

  .paa-rubric__item:last-child {
    border-bottom: none;
  }

  .paa-rubric__question {
    display: flex;
    cursor: pointer;
    list-style: none;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.45;
    color: var(--color-ink);
  }

  .paa-rubric__question::-webkit-details-marker {
    display: none;
  }

  .paa-rubric__question::marker {
    content: "";
  }

  .paa-rubric__question:hover .paa-rubric__question-text {
    color: var(--color-accent);
  }

  .paa-rubric__question-text {
    flex: 1;
    transition: color 0.15s ease;
  }

  .paa-rubric__toggle {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    background: var(--color-surface-muted);
    color: var(--color-ink-muted);
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }

  .paa-rubric__item[open] .paa-rubric__toggle {
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface-muted));
    color: var(--color-accent);
  }

  .paa-rubric__chevron {
    transition: transform 0.2s ease;
  }

  .paa-rubric__item[open] .paa-rubric__chevron {
    transform: rotate(180deg);
  }

  .paa-rubric__answer {
    padding: 0 0 1rem;
  }

  .paa-rubric__answer p {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-ink-muted);
  }
</style>
