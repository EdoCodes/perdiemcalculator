---
import BaseLayout from "../layouts/BaseLayout.astro";
import { CONTACT_EMAIL, CONTACT_FORM_NAME } from "../data/siteContact";

const title = "Contact | PerDiemCalculator";
const description =
  "Contact PerDiemCalculator for feedback, corrections to rate data, or questions about our free per diem calculators and guides.";

const sent = Astro.url.searchParams.has("sent");
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl">
    <h1 class="font-display text-3xl sm:text-4xl">Contact us</h1>
    <p class="mt-4 text-lg leading-relaxed text-[var(--color-ink-muted)]">
      Questions about a calculator result, a broken link, or a rate that looks out of date? Send a message
      below—we read every submission.
    </p>

    {
      sent ? (
        <div
          class="mt-8 rounded-xl border border-[var(--color-accent)]/40 bg-[var(--color-accent-muted)] px-5 py-4 text-[var(--color-ink)]"
          role="status"
        >
          <p class="font-semibold">Message sent</p>
          <p class="mt-2 text-sm text-[var(--color-ink-muted)]">
            Thanks for reaching out. We typically reply within a few business days.
          </p>
        </div>
      ) : (
        <form
          class="contact-form mt-8 space-y-5"
          name={CONTACT_FORM_NAME}
          method="POST"
          action="/contact/?sent=1"
          data-netlify="true"
          netlify-honeypot="bot-field"
        >
          <input type="hidden" name="form-name" value={CONTACT_FORM_NAME} />

          <p class="hidden" aria-hidden="true">
            <label>
              Do not fill this out
              <input name="bot-field" tabindex="-1" autocomplete="off" />
            </label>
          </p>

          <div>
            <label class="contact-form__label" for="contact-name">Your name</label>
            <input
              class="contact-form__input"
              type="text"
              id="contact-name"
              name="name"
              required
              autocomplete="name"
            />
          </div>

          <div>
            <label class="contact-form__label" for="contact-email">Your email</label>
            <input
              class="contact-form__input"
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
            />
          </div>

          <div>
            <label class="contact-form__label" for="contact-subject">Subject (optional)</label>
            <input
              class="contact-form__input"
              type="text"
              id="contact-subject"
              name="subject"
              autocomplete="off"
            />
          </div>

          <div>
            <label class="contact-form__label" for="contact-message">Message</label>
            <textarea
              class="contact-form__input contact-form__textarea"
              id="contact-message"
              name="message"
              rows={6}
              required
            />
          </div>

          <p class="text-sm text-[var(--color-ink-muted)]">
            Please do not send Social Security numbers, full itineraries with passenger names, or other
            sensitive personal data. We cannot provide individual tax or payroll advice.
          </p>

          <button type="submit" class="profession-chip font-semibold">
            Send message
          </button>
        </form>
      )
    }

    <section class="mt-10 border-t border-[var(--color-border)] pt-8">
      <h2 class="text-lg font-semibold text-[var(--color-ink)]">Email directly</h2>
      <p class="mt-2 text-[var(--color-ink-muted)]">
        <a
          class="font-medium text-[var(--color-accent)] hover:underline"
          href={`mailto:${CONTACT_EMAIL}`}
        >
          {CONTACT_EMAIL}
        </a>
      </p>
    </section>

    <h2 class="mt-10 text-xl font-semibold text-[var(--color-ink)]">Before you write</h2>
    <ul class="mt-3 list-disc space-y-2 pl-5 text-[var(--color-ink-muted)]">
      <li>
        Rate questions: check <a class="font-medium text-[var(--color-accent)] hover:underline" href="/methodology/">methodology</a>{" "}
        and your destination on <a class="font-medium text-[var(--color-accent)] hover:underline" href="/states/">state hubs</a>.
      </li>
      <li>
        Wrong profession tool? See <a class="font-medium text-[var(--color-accent)] hover:underline" href="/blog/choose-the-right-calculator/">which calculator to use</a>.
      </li>
      <li>
        All pages: <a class="font-medium text-[var(--color-accent)] hover:underline" href="/sitemap/">HTML sitemap</a>.
      </li>
    </ul>
  </article>
</BaseLayout>

<style>
  .contact-form__label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .contact-form__input {
    margin-top: 0.375rem;
    display: block;
    width: 100%;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border-strong);
    background: var(--color-surface-elevated);
    padding: 0.625rem 0.75rem;
    font-size: 0.9375rem;
    color: var(--color-ink);
  }

  .contact-form__input:focus {
    outline: 2px solid color-mix(in srgb, var(--color-accent) 45%, transparent);
    outline-offset: 1px;
  }

  .contact-form__textarea {
    resize: vertical;
    min-height: 8rem;
  }
</style>
