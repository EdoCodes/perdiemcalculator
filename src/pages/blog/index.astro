---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogRunNumbersCta from "../../components/blog/BlogRunNumbersCta.astro";
import {
  BLOG_POSTS,
  blogCategoryLabel,
  blogPostHref,
  formatBlogDate
} from "../../data/blogPosts";

const title = "Per diem blog — guides, tips, and calculator updates";
const description =
  "Articles on federal GSA per diem, airline crew trip logs, teacher travel, truck driver IRS rates, and how to pick the right calculator.";

const sorted = [...BLOG_POSTS].sort(
  (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);
const articles = sorted.filter((p) => p.kind === "article");
const guides = sorted.filter((p) => p.kind === "guide");
---

<BaseLayout title={title} description={description} hero>
  <article class="mx-auto max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">Blog</p>
    <h1 class="blog-heading font-display mt-4 text-3xl sm:text-4xl lg:text-[2.75rem]">
      Per diem insights for every traveler
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-[var(--color-ink-muted)]">
      Practical articles on GSA rates, crew and trucker tax planning, and how to use our free
      calculators—written for humans and search engines, not filler.
    </p>

    <section class="mt-12">
      <h2 class="blog-heading text-sm font-semibold uppercase tracking-widest text-[var(--color-ink-muted)]">
        Latest articles
      </h2>
      <ul class="mt-6 space-y-4">
        {
          articles.map((post) => (
            <li class="rounded-xl border border-[var(--color-border-strong)] bg-[var(--color-surface-elevated)] p-5 transition hover:border-[var(--color-accent)]">
              <a href={blogPostHref(post)} class="block">
                <p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-accent)]">
                  {blogCategoryLabel(post.category)} · {formatBlogDate(post.publishedAt)}
                </p>
                <h3 class="blog-heading mt-2 font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">
                  {post.title}
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-muted)]">
                  {post.description}
                </p>
                <span class="mt-3 inline-block text-sm font-semibold text-[var(--color-accent)]">
                  Read article →
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14">
      <h2 class="blog-heading text-sm font-semibold uppercase tracking-widest text-[var(--color-ink-muted)]">
        Guides &amp; resources
      </h2>
      <ul class="mt-6 space-y-3">
        {
          guides.map((post) => (
            <li>
              <a
                href={blogPostHref(post)}
                class="group flex flex-col rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-4 py-3 transition hover:border-[var(--color-border-strong)] sm:flex-row sm:items-center sm:justify-between"
              >
                <span class="blog-heading font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">
                  {post.title}
                </span>
                <span class="mt-1 text-xs text-[var(--color-ink-muted)] sm:mt-0">
                  {blogCategoryLabel(post.category)} · Guide
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <BlogRunNumbersCta class="mt-14" />
  </article>
</BaseLayout>
