---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CalculatorProfessionBar } from "../../components/profession/CalculatorProfessionBar";
import { HotelPerDiemCalculator } from "../../components/calculator/HotelPerDiemCalculator";
import { ProfessionPageBrand } from "../../components/profession/ProfessionLogo";

const title = "Hotel management travel per diem calculator | Per Diem Calculator";
const description =
  "Estimate GSA per diem for hospitality corporate trips—property openings, audits, and conferences—and compare company lodging and M&IE to federal caps.";

const siteUrl = Astro.site?.href ?? Astro.url.origin;
const pageUrl = new URL("/calculator/hotel/", siteUrl).href;

const appJsonLd = {
  "@type": "WebApplication",
  name: "Hotel management per diem calculator",
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  url: pageUrl,
  description
};
---

<BaseLayout title={title} description={description} jsonLd={appJsonLd}>
  <section
    class="calculator-theme calc-panel -mx-4 rounded-2xl px-4 py-8 sm:mx-0 sm:px-8 sm:py-10"
  >
    <CalculatorProfessionBar client:load professionId="hotel-manager" />

    <div class="mb-8 max-w-2xl">
      <div class="mt-4">
        <ProfessionPageBrand
          professionId="hotel-manager"
          title="Hotel management travel per diem"
          subtitle="Corporate hospitality travel: GSA lodging and M&IE by destination ZIP—compare company nightly lodging and daily M&IE reimbursement to federal caps."
        />
      </div>
    </div>

    <p class="mb-6 text-sm text-[var(--color-ink-muted)]">
      <a href="/guides/hotel/" class="font-medium text-[var(--color-accent)] hover:underline">Hotel guides</a>
      — corporate travel policy and multi-property trip basics.
    </p>

    <HotelPerDiemCalculator client:load />
  </section>
</BaseLayout>
