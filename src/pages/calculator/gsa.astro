---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CalculatorProfessionBar } from "../../components/profession/CalculatorProfessionBar";
import { PerDiemCalculator } from "../../components/calculator/PerDiemCalculator";

const title = "Federal GSA per diem calculator | Per Diem Calculator";
const description =
  "Calculate federal CONUS per diem with GSA lodging and M&IE rates, travel-day adjustments, and a day-by-day breakdown.";
---

<BaseLayout title={title} description={description}>
  <section
    class="calculator-theme calc-panel -mx-4 rounded-3xl px-4 py-8 sm:mx-0 sm:px-8 sm:py-10"
  >
    <CalculatorProfessionBar client:load professionId="government-federal" />

    <div class="mb-8 max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl">
        Federal GSA per diem
      </h1>
      <p class="mt-3 text-[var(--color-ink-muted)]">
        Government employees and contractors: select destination and trip dates. Rates load from our
        GSA-backed database.
      </p>
    </div>

    <PerDiemCalculator client:load />
  </section>
</BaseLayout>
