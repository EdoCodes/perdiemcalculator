---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CalculatorProfessionBar } from "../../components/profession/CalculatorProfessionBar";
import { PerDiemCalculator } from "../../components/calculator/PerDiemCalculator";
import { ProfessionPageBrand } from "../../components/profession/ProfessionLogo";

const title = "Federal GSA per diem calculator | Per Diem Calculator";
const description =
  "Calculate federal CONUS per diem with GSA lodging and M&IE rates, travel-day adjustments, and a day-by-day breakdown.";
---

<BaseLayout title={title} description={description}>
  <section
    class="calculator-theme calc-panel -mx-4 rounded-2xl px-4 py-8 sm:mx-0 sm:px-8 sm:py-10"
  >
    <CalculatorProfessionBar client:load professionId="government-federal" />

    <div class="mb-8 max-w-2xl">
      <div class="mt-4">
        <ProfessionPageBrand
          professionId="government-federal"
          title="Federal GSA per diem"
          subtitle="Government employees and contractors: select destination and trip dates. Rates load from our GSA-backed database."
        />
      </div>
    </div>

    <PerDiemCalculator client:load />
  </section>
</BaseLayout>
