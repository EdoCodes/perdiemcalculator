---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { PerDiemCalculator } from "../../components/calculator/PerDiemCalculator";

const title = "GSA CONUS per diem calculator";
const description =
  "Calculate federal CONUS per diem with GSA lodging and M&IE rates, travel-day adjustments, and a day-by-day breakdown.";
---

<BaseLayout title={title} description={description}>
  <section
    class="calculator-theme -mx-4 rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-8 shadow-xl shadow-black/40 sm:mx-0 sm:px-8 sm:py-10"
  >
    <div class="mb-8 max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl">
        GSA CONUS calculator
      </h1>
      <p class="mt-3 text-[var(--color-ink-muted)]">
        Select your destination and trip dates. Rates are loaded from our GSA-backed database.
      </p>
    </div>

    <PerDiemCalculator client:load />
  </section>
</BaseLayout>
