---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CalculatorProfessionBar } from "../../components/profession/CalculatorProfessionBar";
import { TeacherPerDiemCalculator } from "../../components/calculator/TeacherPerDiemCalculator";

const title = "Teacher per diem calculator | Per Diem Calculator";
const description =
  "Estimate teacher travel per diem with GSA destination rates plus state education rules (Texas, New Jersey, and more), or enter custom district rates.";
---

<BaseLayout title={title} description={description}>
  <section
    class="calculator-theme calc-panel -mx-4 rounded-3xl px-4 py-8 sm:mx-0 sm:px-8 sm:py-10"
  >
    <CalculatorProfessionBar client:load professionId="education-teacher" />

    <div class="mb-8 max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl">
        Teacher & school staff per diem
      </h1>
      <p class="mt-3 text-[var(--color-ink-muted)]">
        K–12, college, and administrators: use GSA rates for where you travel, with state caps where
        we have official guidance—or switch to custom rates from your district handbook.
      </p>
    </div>

    <TeacherPerDiemCalculator client:load />
  </section>
</BaseLayout>
