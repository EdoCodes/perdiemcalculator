---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ProfessionPicker } from "../../components/profession/ProfessionPicker";

const title = "Choose your profession | Per Diem Calculator";
const description =
  "Select your job role to open the right per diem calculator—federal GSA rates, airline crew, travel nurse and locum stipends, field sales accountable plans, and more.";
---

<BaseLayout title={title} description={description} hero>
  <section class="mx-auto max-w-4xl text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">
      Step 1 of 2
    </p>
    <h1 class="font-display mt-4 text-3xl sm:text-4xl lg:text-[2.75rem]">
      Who needs a per diem estimate?
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-[var(--color-ink-muted)]">
      Per diem rules differ by profession. Pick yours to open a calculator tuned to how you actually get
      paid—official GSA data for federal travel, contract rates for airline crew, healthcare assignments, field sales trips, and more.
    </p>

    <aside
      class="mx-auto mt-8 max-w-2xl rounded-xl border border-[var(--color-border-strong)] bg-[var(--color-surface-elevated)] px-5 py-4 text-center sm:flex sm:items-center sm:justify-between sm:text-left"
    >
      <div>
        <p class="text-sm font-semibold text-[var(--color-ink)]">Corporate travel program?</p>
        <p class="mt-1 text-sm text-[var(--color-ink-muted)]">
          Estimate ROI, payback, and monthly savings from your annual travel spend.
        </p>
      </div>
      <a href="/calculator/roi/" class="profession-chip mt-3 inline-flex sm:mt-0">
        Travel ROI calculator
      </a>
    </aside>

    <div class="mt-10 text-left">
      <ProfessionPicker client:load />
    </div>
  </section>
</BaseLayout>
