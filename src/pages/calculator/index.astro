---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ProfessionPicker } from "../../components/profession/ProfessionPicker";

const title = "Choose your profession | Per Diem Calculator";
const description =
  "Select your job role to open the right per diem calculator—federal GSA rates for government employees, contract rates for airline crew, and more coming soon.";
---

<BaseLayout title={title} description={description} hero>
  <section class="mx-auto max-w-4xl">
    <p
      class="inline-flex items-center rounded-full bg-[var(--color-primary-muted)] px-3 py-1 text-xs font-semibold text-[var(--color-primary)]"
    >
      Step 1 of 2
    </p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl">
      Who needs a per diem estimate?
    </h1>
    <p class="mt-3 max-w-2xl text-lg leading-relaxed text-[var(--color-ink-muted)]">
      Per diem rules differ by profession. Pick yours to open a calculator tuned to how you actually get
      paid—official GSA data for federal travel, contract rates for airline crew, and more on the way.
    </p>

    <div class="mt-10">
      <ProfessionPicker client:load />
    </div>
  </section>
</BaseLayout>
