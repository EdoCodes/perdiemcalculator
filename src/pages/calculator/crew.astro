---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CalculatorProfessionBar } from "../../components/profession/CalculatorProfessionBar";
import { CrewPerDiemCalculator } from "../../components/calculator/CrewPerDiemCalculator";

const title = "Airline crew per diem calculator | Per Diem Calculator";
const description =
  "Estimate per diem for pilots and cabin crew using your contract daily or hourly rates, with domestic and international trip options.";
---

<BaseLayout title={title} description={description}>
  <section
    class="calculator-theme -mx-4 rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-8 shadow-xl shadow-black/40 sm:mx-0 sm:px-8 sm:py-10"
  >
    <CalculatorProfessionBar client:load professionId="aviation-crew" />

    <div class="mb-8 max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl">
        Airline crew per diem
      </h1>
      <p class="mt-3 text-[var(--color-ink-muted)]">
        Pilots and flight attendants: enter your CBA or employer rates for time away from base. This is a
        planning tool—not payroll advice.
      </p>
    </div>

    <CrewPerDiemCalculator client:load />
  </section>
</BaseLayout>
