---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SALES_CALCULATOR_HREF, SALES_GUIDES, salesGuideHref } from "../../../data/salesGuides";

const title = "Field sales per diem guides | Per Diem Calculator";
const description =
  "Guides on accountable-plan per diem, GSA caps for territory travel, and overnight sales trip reimbursement.";
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl">
    <nav class="text-sm text-[var(--color-ink-muted)]" aria-label="Breadcrumb">
      <a class="hover:text-[var(--color-accent)]" href="/">Home</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-ink)]">Sales guides</span>
    </nav>

    <h1 class="font-display mt-6 text-3xl sm:text-4xl">Field sales per diem guides</h1>
    <p class="mt-4 text-lg leading-relaxed text-[var(--color-ink-muted)]">
      Sales teams on multi-day territory trips often use <strong class="text-[var(--color-ink)]">IRS accountable plans</strong>{" "}
      tied to federal GSA per diem. Use the calculator, then read the guides below.
    </p>

    <a href={SALES_CALCULATOR_HREF} class="profession-chip mt-6 inline-flex font-semibold">
      Field sales per diem calculator
    </a>

    <ul class="mt-10 space-y-4">
      {
        SALES_GUIDES.map((g) => (
          <li class="rounded-xl border border-[var(--color-border-strong)] bg-[var(--color-surface-elevated)] p-5">
            <a href={salesGuideHref(g.slug)} class="font-semibold text-[var(--color-ink)] hover:text-[var(--color-accent)]">
              {g.title}
            </a>
            <p class="mt-2 text-sm text-[var(--color-ink-muted)]">{g.description}</p>
          </li>
        ))
      }
    </ul>
  </article>
</BaseLayout>
