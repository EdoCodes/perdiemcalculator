---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { POLICE_CALCULATOR_HREF, POLICE_GUIDES, policeGuideHref } from "../../../data/policeGuides";

const title = "Police & law enforcement per diem guides | Per Diem Calculator";
const description =
  "Guides on when officers receive per diem, GSA CONUS rates vs department policy, and out-of-town training and court travel.";
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl">
    <nav class="text-sm text-[var(--color-ink-muted)]" aria-label="Breadcrumb">
      <a class="hover:text-[var(--color-accent)]" href="/">Home</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-ink)]">Police guides</span>
    </nav>

    <h1 class="font-display mt-6 text-3xl sm:text-4xl">Police & law enforcement per diem guides</h1>
    <p class="mt-4 text-lg leading-relaxed text-[var(--color-ink-muted)]">
      Out-of-town travel for training, court, mutual aid, and federal task forces often uses{" "}
      <strong class="text-[var(--color-ink)]">GSA CONUS rates</strong> or a local agency schedule. Use the
      calculator, then read the guides below.
    </p>

    <a href={POLICE_CALCULATOR_HREF} class="profession-chip mt-6 inline-flex font-semibold">
      Police travel per diem calculator
    </a>

    <ul class="mt-10 space-y-4">
      {
        POLICE_GUIDES.map((g) => (
          <li class="rounded-xl border border-[var(--color-border-strong)] bg-[var(--color-surface-elevated)] p-5">
            <a href={policeGuideHref(g.slug)} class="font-semibold text-[var(--color-ink)] hover:text-[var(--color-accent)]">
              {g.title}
            </a>
            <p class="mt-2 text-sm text-[var(--color-ink-muted)]">{g.description}</p>
          </li>
        ))
      }
    </ul>
  </article>
</BaseLayout>
