---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getStateByAbbr, US_STATES } from "../../data/usStates";

export function getStaticPaths() {
  return US_STATES.map((s) => ({
    params: { abbr: s.abbr.toLowerCase() }
  }));
}

const abbrParam = Astro.params.abbr ?? "";
const state = getStateByAbbr(abbrParam);

if (!state) {
  return Astro.redirect("/states/");
}

const title = `${state.name} per diem rates (GSA CONUS)`;
const description = `GSA CONUS per diem for ${state.name}: standard rate, high-cost localities, and calculator links.`;
const calcHref = `/calculator/gsa/?state=${state.abbr}`;
---

<BaseLayout title={title} description={description}>
  <nav class="text-sm text-[var(--color-ink-muted)]">
    <a class="hover:text-[var(--color-primary)]" href="/">Home</a>
    <span class="mx-2">/</span>
    <a class="hover:text-[var(--color-primary)]" href="/states/">States</a>
    <span class="mx-2">/</span>
    <span class="text-[var(--color-ink)]">{state.name}</span>
  </nav>

  <h1 class="mt-6 text-3xl font-bold tracking-tight text-[var(--color-ink)]">
    {state.name} per diem
  </h1>
  <p class="mt-3 max-w-2xl text-[var(--color-ink-muted)]">
    GSA publishes a <strong>standard CONUS rate</strong> for {state.name} plus higher rates for
    listed counties and cities. Use the calculator to pick a locality and see seasonal lodging.
  </p>

  <div class="mt-8 flex flex-wrap gap-3">
    <a
      href={calcHref}
      class="inline-flex items-center justify-center rounded-xl bg-[var(--color-primary)] px-5 py-2.5 text-sm font-semibold text-white shadow-md hover:bg-[var(--color-primary-hover)]"
      >Calculate for {state.abbr}</a
    >
    <a
      href="/methodology/"
      class="inline-flex items-center justify-center rounded-xl border border-[var(--color-border)] px-5 py-2.5 text-sm font-semibold text-[var(--color-ink)] hover:bg-[var(--color-surface-muted)]"
      >Methodology</a
    >
  </div>

  <div
    class="mt-10 rounded-2xl border border-dashed border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-6 text-sm text-[var(--color-ink-muted)]"
  >
    Locality list for {state.abbr} appears here after GSA data sync. Open the calculator to search
    all synced destinations for this state.
  </div>
</BaseLayout>
