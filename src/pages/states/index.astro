---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { US_STATES } from "../../data/usStates";

const title = "Per diem by state (CONUS)";
const description =
  "State hub pages for GSA CONUS per diem localities and standard-rate context.";
---

<BaseLayout title={title} description={description}>
  <h1 class="text-3xl font-bold tracking-tight text-[var(--color-ink)]">States</h1>
  <p class="mt-2 max-w-2xl text-[var(--color-ink-muted)]">
    Choose a state to learn more, then open the calculator with your destination pre-selected.
  </p>
  <ul class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      US_STATES.map((s) => (
        <li>
          <a
            href={`/states/${s.abbr.toLowerCase()}/`}
            class="flex items-center justify-between rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-4 py-4 transition hover:border-[var(--color-primary)]/40 hover:shadow-md"
          >
            <span class="font-semibold text-[var(--color-ink)]">{s.name}</span>
            <span class="rounded-lg bg-[var(--color-surface-muted)] px-2 py-1 text-xs font-bold text-[var(--color-ink-muted)]">
              {s.abbr}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
