---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CREW_CALCULATOR_HREF, CREW_GUIDES_INDEX, crewGuideHref } from "../../data/crewGuides";

const title = "Flight attendant per diem calculator (GSA & trip log)";
const description =
  "Free per diem calculator for flight attendants and cabin crew: layover GSA M&IE, contract compare, trip log, schedule upload, and tax-season exports.";
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl">
    <h1 class="text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl">
      Flight attendant per diem calculator
    </h1>
    <p class="mt-4 text-base leading-relaxed text-[var(--color-ink-muted)]">
      <strong class="text-[var(--color-ink)]">Cabin crew and flight attendants</strong> can log each
      pairing with layover airport, dates away from base, and daily GSA M&amp;IE—alongside optional
      contract per diem rates from your airline. Built for busy month-to-month schedules and
      year-end summaries.
    </p>
    <ul class="mt-6 list-disc space-y-2 pl-5 text-[var(--color-ink-muted)]">
      <li>Free trip history, calendar view, CSV and print/PDF</li>
      <li>Upload roster CSV or paste schedule lines</li>
      <li>
        <a class="text-[var(--color-primary)] hover:underline" href={crewGuideHref("multi-city-layovers")}
          >Multi-city layover</a
        > assignment for long trips
      </li>
    </ul>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={CREW_CALCULATOR_HREF}
        class="inline-flex rounded-xl bg-[var(--color-primary)] px-5 py-2.5 text-sm font-semibold text-white hover:bg-[var(--color-primary-hover)]"
      >
        Open crew calculator
      </a>
      <a
        href="/crew/layover/"
        class="inline-flex rounded-xl border border-[var(--color-border)] px-5 py-2.5 text-sm font-semibold hover:bg-[var(--color-surface-muted)]"
      >
        Layover hub pages
      </a>
    </div>
    <p class="mt-10 text-sm text-[var(--color-ink-muted)]">
      Also for <a class="text-[var(--color-primary)] hover:underline" href="/crew/pilots/">pilots</a> ·
      <a class="text-[var(--color-primary)] hover:underline" href={CREW_GUIDES_INDEX}>All crew guides</a>
    </p>
  </article>
</BaseLayout>
