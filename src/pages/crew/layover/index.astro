---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { CREW_HUB_AIRPORTS } from "../../../data/crewHubAirports";
import { CREW_CALCULATOR_HREF, CREW_GUIDES_INDEX } from "../../../data/crewGuides";
import { fiscalYearForDate } from "../../../lib/perdiem/fiscalYear";

const fy = fiscalYearForDate(new Date());
const title = `Airline crew layover per diem by airport (FY ${fy})`;
const description =
  "GSA M&IE layover reference for busy U.S. airline hubs—DFW, LAX, ORD, ATL, and more—with links to the free crew trip log calculator.";
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl">
    <nav class="text-sm text-[var(--color-ink-muted)]" aria-label="Breadcrumb">
      <a class="hover:text-[var(--color-primary)]" href="/">Home</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-ink)]">Layover hubs</span>
    </nav>

    <h1 class="mt-6 text-3xl font-bold tracking-tight text-[var(--color-ink)]">
      Layover per diem by airport
    </h1>
    <p class="mt-4 text-[var(--color-ink-muted)]">
      Quick GSA M&amp;IE context for major U.S. crew layover airports (federal fiscal year {fy}).
      For full trip chains and tax-year totals, use the
      <a class="font-medium text-[var(--color-primary)] hover:underline" href={CREW_CALCULATOR_HREF}
        >airline crew calculator</a
      >.
    </p>

    <ul class="mt-10 grid gap-3 sm:grid-cols-2">
      {
        CREW_HUB_AIRPORTS.map((a) => (
          <li>
            <a
              class="block rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-4 py-3 hover:border-[var(--color-primary)]/40"
              href={`/crew/layover/${a.code.toLowerCase()}/`}
            >
              <span class="font-mono font-bold text-[var(--color-ink)]">{a.code}</span>
              <span class="mt-0.5 block text-sm text-[var(--color-ink-muted)]">{a.city}, {a.state}</span>
            </a>
          </li>
        ))
      }
    </ul>

    <p class="mt-10">
      <a class="text-sm font-medium text-[var(--color-primary)] hover:underline" href={CREW_GUIDES_INDEX}>
        ← Crew guides
      </a>
    </p>
  </article>
</BaseLayout>
