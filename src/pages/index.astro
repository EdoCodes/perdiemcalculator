---
import BaseLayout from "../layouts/BaseLayout.astro";
import { US_STATES } from "../data/usStates";

const title = "Federal GSA per diem calculator (CONUS)";
const description =
  "Estimate CONUS per diem with official GSA lodging and M&IE rates, travel-day adjustments, and day-by-day breakdowns.";

const siteUrl = Astro.site?.href ?? Astro.url.origin;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "PerDiemCalculator",
    url: siteUrl,
    description
  }
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd} hero>
  <section class="relative overflow-hidden rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-6 py-14 shadow-xl shadow-black/5 sm:px-12 sm:py-16">
    <div class="relative z-10 max-w-2xl">
      <p
        class="inline-flex items-center rounded-full bg-[var(--color-primary-muted)] px-3 py-1 text-xs font-semibold text-[var(--color-primary)]"
      >
        Official GSA CONUS data
      </p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-[var(--color-ink)] sm:text-5xl">
        Per diem, calculated with precision
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-[var(--color-ink-muted)]">
        Seasonal lodging, M&IE tiers, travel-day rules, and meal deductions — in one modern
        calculator built for federal travelers and contractors.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/calculator/gsa/"
          class="inline-flex items-center justify-center rounded-xl bg-[var(--color-primary)] px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-[var(--color-primary)]/30 transition hover:bg-[var(--color-primary-hover)]"
          >Start calculating</a
        >
        <a
          href="/methodology/"
          class="inline-flex items-center justify-center rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-6 py-3 text-sm font-semibold text-[var(--color-ink)] transition hover:bg-[var(--color-surface-elevated)]"
          >How it works</a
        >
      </div>
    </div>
  </section>

  <section class="mt-16 grid gap-6 sm:grid-cols-3">
    {
      [
        {
          title: "Real GSA rates",
          body: "Localities, monthly lodging caps, and M&IE synced from the federal Per Diem API."
        },
        {
          title: "FTR-aware options",
          body: "75% travel days, meal deductions, optional 150% lodging display."
        },
        {
          title: "Day-by-day clarity",
          body: "Transparent breakdown for audits, vouchers, and trip planning."
        }
      ].map((item) => (
        <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-6 shadow-sm">
          <h2 class="font-semibold text-[var(--color-ink)]">{item.title}</h2>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-muted)]">{item.body}</p>
        </div>
      ))
    }
  </section>

  <section class="mt-16">
    <div class="flex items-end justify-between gap-4">
      <div>
        <h2 class="text-2xl font-bold text-[var(--color-ink)]">Browse by state</h2>
        <p class="mt-1 text-sm text-[var(--color-ink-muted)]">
          Open a state hub or jump straight into the calculator.
        </p>
      </div>
      <a href="/states/" class="hidden text-sm font-semibold text-[var(--color-primary)] sm:inline hover:underline"
        >View all</a
      >
    </div>
    <ul class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        US_STATES.map((s) => (
          <li>
            <a
              href={`/states/${s.abbr.toLowerCase()}/`}
              class="group flex items-center justify-between rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-4 py-3.5 transition hover:border-[var(--color-primary)]/40 hover:shadow-md"
            >
              <span class="font-medium text-[var(--color-ink)] group-hover:text-[var(--color-primary)]">
                {s.name}
              </span>
              <span class="text-xs font-bold text-[var(--color-ink-muted)]">{s.abbr}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
