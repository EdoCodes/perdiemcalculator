---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ProfessionPicker } from "../components/profession/ProfessionPicker";
import { US_STATES } from "../data/usStates";

const title = "Per diem calculator for every profession";
const description =
  "Estimate per diem for federal government travel (GSA CONUS), airline pilots and cabin crew, and more—pick your profession and calculate.";

const siteUrl = Astro.site?.href ?? Astro.url.origin;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "PerDiemCalculator",
    url: siteUrl,
    description
  }
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd} hero>
  <section class="relative overflow-hidden rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-6 py-14 shadow-xl shadow-black/5 sm:px-12 sm:py-16">
    <div class="relative z-10 max-w-3xl">
      <p
        class="inline-flex items-center rounded-full bg-[var(--color-primary-muted)] px-3 py-1 text-xs font-semibold text-[var(--color-primary)]"
      >
        perdiemcalculator.com
      </p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-[var(--color-ink)] sm:text-5xl">
        Per diem, for your profession
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-[var(--color-ink-muted)]">
        One site, many pay systems—GSA for federal travelers, contract rates for airline crew, school
        policy for teachers, and more on the way.
      </p>
    </div>
  </section>

  <section class="mt-14">
    <div class="mx-auto max-w-4xl">
      <h2 class="text-2xl font-bold text-[var(--color-ink)]">Choose your profession</h2>
      <p class="mt-2 text-sm text-[var(--color-ink-muted)]">
        Step 1: select how you earn per diem. Step 2: run a calculator built for those rules.
      </p>
      <div class="mt-8">
        <ProfessionPicker client:load />
      </div>
    </div>
  </section>

  <section class="mt-16 grid gap-6 sm:grid-cols-3">
    {
      [
        {
          title: "Federal GSA rates",
          body: "Localities, monthly lodging caps, and M&IE synced from the federal Per Diem API."
        },
        {
          title: "Airline crew",
          body: "Per day or per hour away from base—domestic and international, with your contract rates."
        },
        {
          title: "Teachers & school staff",
          body: "Conferences, field trips, and PD—daily M&IE plus lodging from your district policy."
        }
      ].map((item) => (
        <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-6 shadow-sm">
          <h2 class="font-semibold text-[var(--color-ink)]">{item.title}</h2>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-muted)]">{item.body}</p>
        </div>
      ))
    }
  </section>

  <section class="mt-16">
    <div class="flex items-end justify-between gap-4">
      <div>
        <h2 class="text-2xl font-bold text-[var(--color-ink)]">Federal travelers: browse by state</h2>
        <p class="mt-1 text-sm text-[var(--color-ink-muted)]">
          GSA CONUS rate hubs for government employees and contractors.
        </p>
      </div>
      <a href="/states/" class="hidden text-sm font-semibold text-[var(--color-primary)] sm:inline hover:underline"
        >View all</a
      >
    </div>
    <ul class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        US_STATES.map((s) => (
          <li>
            <a
              href={`/states/${s.abbr.toLowerCase()}/`}
              class="group flex items-center justify-between rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-4 py-3.5 transition hover:border-[var(--color-primary)]/40 hover:shadow-md"
            >
              <span class="font-medium text-[var(--color-ink)] group-hover:text-[var(--color-primary)]">
                {s.name}
              </span>
              <span class="text-xs font-bold text-[var(--color-ink-muted)]">{s.abbr}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
