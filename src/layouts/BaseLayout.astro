---
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  /** Optional JSON-LD object or array of objects (serialized as application/ld+json). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
};

const { title, description, jsonLd } = Astro.props;

const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : new URL(Astro.url.pathname, Astro.url.origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {
      jsonLd ? (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      ) : null
    }
  </head>
  <body class="min-h-dvh bg-zinc-50 text-zinc-900 antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-3 focus:py-2 focus:shadow"
      >Skip to content</a
    >

    <header class="border-b border-zinc-200 bg-white">
      <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-4 py-4">
        <a href="/" class="text-base font-semibold tracking-tight text-zinc-900">
          Per diem calculator
        </a>
        <nav class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-medium text-zinc-700">
          <a href="/calculator/gsa/" class="hover:text-zinc-950">GSA calculator</a>
          <a href="/methodology/" class="hover:text-zinc-950">Methodology</a>
          <a href="/states/" class="hover:text-zinc-950">States</a>
        </nav>
      </div>
    </header>

    <main id="main" class="mx-auto max-w-5xl px-4 py-10">
      <slot />
    </main>

    <footer class="border-t border-zinc-200 bg-white">
      <div class="mx-auto max-w-5xl px-4 py-8 text-sm text-zinc-600">
        <p>
          This site is a planning aid. Reimbursement rules are governed by your agency and the
          <a
            class="text-zinc-900 underline decoration-zinc-300 underline-offset-4 hover:decoration-zinc-900"
            href="https://www.ecfr.gov/current/title-41/subtitle-F"
            >Federal Travel Regulation</a
          >. Official CONUS rates are published by
          <a
            class="text-zinc-900 underline decoration-zinc-300 underline-offset-4 hover:decoration-zinc-900"
            href="https://www.gsa.gov/travel/plan-book/per-diem-rates"
            >GSA</a
          >.
        </p>
      </div>
    </footer>
  </body>
</html>
