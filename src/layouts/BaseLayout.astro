---
import "../styles/global.css";
import { ThemeToggle } from "../components/ThemeToggle";

type Props = {
  title: string;
  description: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  hero?: boolean;
};

const { title, description, jsonLd, hero = false } = Astro.props;

const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : new URL(Astro.url.pathname, Astro.url.origin).href;

const navLink =
  "text-sm font-medium text-[var(--color-ink-muted)] transition hover:text-[var(--color-ink)]";
const navActive = "text-sm font-semibold text-[var(--color-accent)]";
const path = Astro.url.pathname;

const onCalculator =
  path.startsWith("/calculator") || path === "/";
const onStates = path.startsWith("/states");
const onMethodology = path.startsWith("/methodology");
const onCrewGuides =
  path.startsWith("/guides/crew") || path.startsWith("/crew/");
const onTruckingGuides = path.startsWith("/guides/trucking");
const onBlog = path.startsWith("/blog");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const dark = stored === "dark";
        document.documentElement.classList.toggle("dark", dark);
      })();
    </script>
    {
      jsonLd ? (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(
            Array.isArray(jsonLd)
              ? { "@context": "https://schema.org", "@graph": jsonLd }
              : jsonLd
          )}
        />
      ) : null
    }
  </head>
  <body class:list={["min-h-dvh antialiased", hero ? "bg-mesh" : "bg-[var(--color-surface)]"]}>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-[var(--color-surface-elevated)] focus:px-3 focus:py-2 focus:shadow"
      >Skip to content</a
    >

    <header class="glass sticky top-0 z-40 border-b border-[var(--color-border)]">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-3.5 sm:px-6">
        <a href="/" class="flex items-center gap-2.5">
          <span
            class="flex h-9 w-9 items-center justify-center rounded-lg bg-[var(--color-ink)] text-sm font-bold text-white"
            >PD</span
          >
          <span class="text-sm font-bold tracking-tight text-[var(--color-ink)] sm:text-base"
            >PerDiemCalculator</span
          >
        </a>
        <nav class="flex flex-wrap items-center gap-x-5 gap-y-2">
          <a href="/calculator/" class={onCalculator ? navActive : navLink}>Calculators</a>
          <a href="/blog/" class={onBlog ? navActive : navLink}>Blog</a>
          <a href="/guides/crew/" class={onCrewGuides ? navActive : navLink}>Crew guides</a>
          <a href="/guides/trucking/" class={onTruckingGuides ? navActive : navLink}>Trucker guides</a>
          <a href="/states/" class={onStates ? navActive : navLink}>States</a>
          <a href="/methodology/" class={onMethodology ? navActive : navLink}>Methodology</a>
          <ThemeToggle client:load />
        </nav>
      </div>
    </header>

    <main id="main" class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
      <slot />
    </main>

    <footer class="mt-16 border-t border-[var(--color-border)] bg-[var(--color-surface-elevated)]">
      <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-sm text-[var(--color-ink-muted)]">
            Planning aid only · Not payroll or tax advice · Verify with your employer or agency
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="/calculator/"
              class="text-sm font-semibold text-[var(--color-accent)] hover:underline"
              >Calculators</a
            >
            <a href="/blog/" class="text-sm font-semibold text-[var(--color-accent)] hover:underline"
              >Blog</a
            >
            <a
              href="/guides/crew/"
              class="text-sm font-semibold text-[var(--color-accent)] hover:underline"
              >Crew guides</a
            >
          </div>
        </div>
    </footer>
  </body>
</html>
