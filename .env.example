# Copy to `.env` for local development (never commit real secrets).

# Canonical site URL for sitemaps, canonical tags, and JSON-LD. Set this in Netlify UI too.
PUBLIC_SITE_URL=http://localhost:4321

# Supabase (public anon key is safe for browsers; keep service role keys server-only).
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
