# Optional: copy to `.env` for local development (never commit `.env`).
# Cloud setup: use GitHub Actions "Sync GSA rates" + Netlify env vars (no local .env required).

# Canonical site URL (Netlify: set PUBLIC_SITE_URL to your live URL, then redeploy).
PUBLIC_SITE_URL=http://localhost:4321

# Supabase → Project Settings → API (use Project URL + anon public key in the browser).
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only (local sync script — never add to Netlify or prefix with PUBLIC_).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Free key: https://open.gsa.gov/api/perdiem/
GSA_API_KEY=
